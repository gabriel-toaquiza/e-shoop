# ── Plantilla de variables de entorno ─────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# El .env NUNCA se sube al repositorio (está en .gitignore).

# Clave secreta de Flask (firma de sesiones/cookies).
# En producción genera una fuerte:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave

# Base de datos (MySQL / MariaDB)
DB_USER=ecommerce_user
DB_PASSWORD=123456
DB_HOST=localhost
DB_NAME=ecommerce_db

# ── Modo de ejecución ─────────────────────────────────────────────
# Desarrollo: FLASK_DEBUG=1  (recarga y errores detallados)
# Producción: FLASK_DEBUG=0  (o no la definas)
FLASK_DEBUG=1
# Legado de Flask; en producción: production
FLASK_ENV=development

# Host y puerto (opcionales; por defecto 127.0.0.1:5000)
HOST=127.0.0.1
PORT=5000

# Cookies solo por HTTPS (actívalo a 1 solo cuando el servidor use HTTPS)
SESSION_COOKIE_SECURE=0
